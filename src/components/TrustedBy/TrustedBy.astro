---
import './TrustedBy.css';
// An unnumbered logo wall — a quiet band of mono-colour brand marks, sitting
// between the Approach (03) and the dark Contact close (04). Deliberately
// outside the foliation so the 01–04 section index stays intact.
//
// Logos are sourced from `src/assets/logos/*.svg` and inlined so they render
// with `fill="currentColor"` and inherit the theme — they recolour for dark
// mode automatically. Two-tone marks keep their knockout details via
// `fill: var(--surface)`, so the cut-outs read as holes onto the page ground.
//
// The roster is explicit (not filename-derived) so display order is intentional
// and each mark gets a correct accessible name. To add a brand: drop a mono SVG
// (currentColor for the ink, no hard-coded fills) into that folder and add a
// `{ slug, name, url }` entry below. A mark with no `url` renders unlinked.
const logoModules = import.meta.glob<string>('../../assets/logos/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});

// Order is tuned for the wall's rhythm, not alphabetised. Every mark renders at
// a uniform height, so a logo's optical weight tracks its aspect ratio: the two
// near-square marks (Co-op, Unilever) read as compact, the rest as wide
// wordmarks. We split the two compact marks one-per-row and seat each between
// wider neighbours, and lead each row with a substantial wordmark — so at the
// desktop 4/3 wrap the rows balance (Equal Experts · Co-op · Allgold · Neem /
// Snotbricks · Unilever · Stage Two) instead of stranding a tiny mark in a corner.
const brands = [
  { slug: 'equal-experts', name: 'Equal Experts', url: 'https://www.equalexperts.com' },
  { slug: 'co-operative', name: 'The Co-operative', url: 'https://www.coop.co.uk' },
  { slug: 'allgold', name: 'Allgold', url: 'https://allgold.com' },
  { slug: 'neem', name: 'Neem', url: 'https://weareneem.com' },
  // `shift` nudges a mark down (% of its own height) to sit on the shared
  // baseline — Snotbricks' wordmark rides high because its emblem drips below.
  { slug: 'snotbricks', name: 'Snotbricks & Co.', shift: '8%', url: 'https://snotbricks.com' },
  { slug: 'unilever', name: 'Unilever', url: 'https://www.unilever.com' },
  { slug: 'stage-two', name: 'Stage Two', shift: '5%', url: 'https://wearestagetwo.com' },
];

const logos = brands
  .map((brand) => ({ ...brand, svg: logoModules[`../../assets/logos/${brand.slug}.svg`] }))
  .filter((brand) => brand.svg);
---

<section id="trusted-by" class="trusted-by" aria-labelledby="trusted-by-heading">
  <div class="wrap">
    <p id="trusted-by-heading" class="eyebrow trusted-by__eyebrow" data-reveal>
      Trusted by
    </p>

    <ul class="trusted-by__list">
      {
        logos.map((logo, i) => (
          <li
            class="trusted-by__logo"
            data-reveal
            style={`--reveal-delay: ${i * 60}ms; --logo-shift: ${logo.shift ?? '0'}`}
          >
            {/* The <li> stays a listitem; the image role + name live on the mark
                wrapper, a valid host for role="img" (the inlined SVG becomes
                presentational under it). When the brand has a site, the mark is
                wrapped in a link — which takes its accessible name from the
                contained role="img", so it reads as "{name}, link". */}
            {logo.url ? (
              <a
                class="trusted-by__link"
                href={logo.url}
                target="_blank"
                rel="noopener"
              >
                <span class="trusted-by__mark" role="img" aria-label={logo.name} set:html={logo.svg} />
              </a>
            ) : (
              <span class="trusted-by__mark" role="img" aria-label={logo.name} set:html={logo.svg} />
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>
