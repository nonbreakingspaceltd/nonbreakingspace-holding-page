---
import Wordmark from '../Wordmark';

const email = 'hello@nonbreakingspace.co.uk';
---

<section id="contact" class="contact on-navy" aria-labelledby="contact-heading">
  <div class="wrap contact__inner">
    <p class="eyebrow contact__eyebrow" data-reveal>Start the conversation</p>

    <h2 id="contact-heading" class="t-cta contact__headline" data-reveal style="--reveal-delay: 80ms">
      Let&rsquo;s make something to be <em>proud</em> of.
    </h2>

    <a
      class="t-email link-underline contact__email"
      href={`mailto:${email}`}
      data-reveal
      style="--reveal-delay: 160ms"
    >
      {email}
    </a>

    <div class="contact__colophon" data-reveal>
      <div class="contact__legal">
        <p class="legal">Nonbreakingspace Ltd&nbsp;&middot;&nbsp;Company no. 10833071</p>
        <p class="legal">Manchester, UK&nbsp;&middot;&nbsp;&copy; Copyright 2026&nbsp;&middot;&nbsp;<a
            class="link-underline contact__brand-link"
            href="/brand">Brand guidelines</a></p>
      </div>
      <span class="contact__wordmark" aria-hidden="true">
        <Wordmark />
      </span>
    </div>
  </div>

  {/* Fixed wayfinding control. Mirror of the skip link: returns to the masthead
      (#top) and moves focus there, smooth-scrolling via the global
      html { scroll-behavior }. Hidden until the masthead has scrolled away and
      again once the footer is in view (see the reveal script below). Icon-only —
      the label lives in aria-label / title for assistive tech and tooltip. */}
  <a class="contact__totop" href="#top" aria-label="Back to top" title="Back to top">
    <svg
      class="contact__totop-icon"
      viewBox="0 0 24 24"
      width="16"
      height="16"
      fill="none"
      stroke="currentColor"
      stroke-width="1.9"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M12 19V5M6 11l6-6 6 6"></path>
    </svg>
  </a>
</section>

<script>
  // Reveal the fixed back-to-top once the masthead (#top) has scrolled out of
  // view (hidden at the very top). It then stays visible all the way down,
  // including over the navy footer — but there it would blend into the dark
  // ground, so the footer observer flips it to the inverted palette
  // (.is-over-dark) instead of hiding it.
  const btn = document.querySelector('.contact__totop');
  const top = document.getElementById('top');
  const contact = document.getElementById('contact');

  if (btn && top) {
    let atTop = true;
    let overFooter = false;
    const update = () => {
      btn.classList.toggle('is-visible', !atTop);
      btn.classList.toggle('is-over-dark', overFooter);
    };

    new IntersectionObserver(([e]) => {
      atTop = e.isIntersecting;
      update();
    }).observe(top);

    if (contact) {
      new IntersectionObserver(
        ([e]) => {
          overFooter = e.isIntersecting;
          update();
        },
        // Shrink the root up from the bottom so the flip fires when the footer
        // actually reaches the button's band, not when it first peeks in.
        { rootMargin: '0px 0px -64px 0px' },
      ).observe(contact);
    }
  }
</script>

<style>
  .contact {
    background: var(--surface-contrast);
    color: var(--text-on-contrast);
    padding-block: var(--pad-contact);
    /* Keyline separating the footer from the section above. */
    border-top: 1px solid var(--rule-contrast);
  }

  .contact__eyebrow {
    color: color-mix(in srgb, var(--text-on-contrast) 72%, transparent);
    margin-bottom: clamp(1.75rem, 5vh, 3rem);
  }

  .contact__headline {
    color: var(--text-on-contrast);
    max-width: 16ch;
  }

  .contact__email {
    display: inline-block;
    width: max-content;
    max-width: 100%;
    margin-top: clamp(1.75rem, 4vh, 2.75rem);
    color: var(--text-on-contrast);
    /* comfortable tap target */
    padding-block: 0.35rem;
  }

  .contact__colophon {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-top: clamp(4.5rem, 12vh, 8rem);
    padding-top: clamp(1.5rem, 3vh, 2.25rem);
    border-top: 1px solid var(--rule-contrast);
  }

  .contact__legal .legal {
    color: color-mix(in srgb, var(--text-on-contrast) 70%, transparent);
  }
  .contact__legal .legal + .legal {
    margin-top: 0.35rem;
  }
  /* Quiet inline link to the brand spec; brightens to full ink on hover. */
  .contact__brand-link:hover,
  .contact__brand-link:focus-visible {
    color: var(--text-on-contrast);
  }

  /* Fixed circular wayfinding button. Pinned to the viewport corner; it floats
     over the page ground (not the footer), so it inverts against that ground in
     BOTH themes — disc = the display ink (--text-strong), arrow cut out in the
     ground colour (--surface). Light: navy disc / ivory arrow. Dark: near-ivory
     disc / navy arrow. Revealed/hidden by the reveal script via .is-visible. */
  .contact__totop {
    position: fixed;
    right: clamp(1rem, 4vw, 2.5rem);
    bottom: clamp(1rem, 4vw, 2.5rem);
    z-index: 50;
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    /* Slightly translucent at rest so the ground reads through; solidifies on hover. */
    background: color-mix(in srgb, var(--text-strong) 90%, transparent);
    color: var(--surface);
    /* Hidden state — faded out, lifted, and inert until scrolled into play. */
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.5rem);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0s linear 0.3s,
      background-color 0.25s ease,
      color 0.25s ease;
  }
  .contact__totop.is-visible {
    opacity: 1;
    visibility: visible;
    transform: none;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0s,
      background-color 0.25s ease,
      color 0.25s ease;
  }
  /* Over the navy footer the default ink disc would vanish — invert it so it
     stays a legible ivory disc with a navy arrow on the dark ground. */
  .contact__totop.is-over-dark {
    background: color-mix(in srgb, var(--text-on-contrast) 90%, transparent);
    color: var(--surface-contrast);
  }
  .contact__totop:hover,
  .contact__totop:focus-visible {
    background: var(--text-strong);
  }
  .contact__totop.is-over-dark:hover,
  .contact__totop.is-over-dark:focus-visible {
    background: var(--text-on-contrast);
  }
  /* Focus ring: the inherited .on-navy ivory ring is invisible over the light
     ground, so use ink there; flip back to ivory once over the dark footer. */
  .contact__totop:focus-visible {
    outline-color: var(--text-strong);
  }
  .contact__totop.is-over-dark:focus-visible {
    outline-color: var(--text-on-contrast);
  }
  .contact__totop-icon {
    flex: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .contact__totop {
      transform: none;
      transition:
        opacity 0.2s ease,
        visibility 0s linear 0.2s,
        border-color 0.2s ease,
        background-color 0.2s ease;
    }
  }

  .contact__wordmark {
    flex: none;
  }
  .contact__wordmark :global(svg) {
    display: block;
    width: clamp(120px, 22vw, 168px);
    height: auto;
    color: var(--text-on-contrast);
  }

  @media (max-width: 34rem) {
    .contact__colophon {
      flex-direction: column;
      align-items: flex-start;
      gap: clamp(2rem, 8vw, 3rem);
    }
  }
</style>
