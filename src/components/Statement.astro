---
// An unnumbered interstitial — a single oversized editorial manifesto. The
// whitespace around it is the design: the most vertical air on the light page.
---

<section id="statement" class="statement" aria-labelledby="statement-text">
  <div class="wrap">
    <h2 id="statement-text" class="t-statement statement__text" data-reveal>
      We are a small studio creating software, interfaces and visual systems that work for
      <em>everyone</em>.
    </h2>
  </div>
</section>

<style>
  .statement {
    border-top: 1px solid var(--rule-light);
    border-bottom: 1px solid var(--rule-light);
    padding-block: var(--pad-statement);
  }

  /* Flush-left with the section labels; the wide right margin frames it.
     `balance` evens the rag across this short display block. */
  .statement__text {
    max-width: 24ch;
    text-wrap: balance;
  }
</style>
