---
import './NotFound.css';
import Wordmark from '../Wordmark';

// The 404 view — a single centred "non-breaking space" message. Self-contained
// so the 404 page is just <BaseLayout><NotFound /></BaseLayout>.
---

<main class="notfound" id="index" tabindex="-1">
  <div class="wrap notfound__inner">
    <span
      class="notfound__wordmark reveal-draw"
      data-reveal
      style="--reveal-delay: 120ms"
      aria-hidden="true"
    >
      <Wordmark animated />
    </span>

    <div class="notfound__lower">
      <p class="eyebrow" data-reveal style="--reveal-delay: 420ms">
        <span class="index">404</span>&nbsp;&mdash;&nbsp;Page not found
      </p>

      <h1 class="t-statement notfound__title" data-reveal style="--reveal-delay: 500ms">
        You&rsquo;ve found a non&#8209;breaking&nbsp;space.
      </h1>

      <p class="t-body notfound__body" data-reveal style="--reveal-delay: 620ms">
        The address may be mistyped, or the page has moved on. Everything else is
        right where you left&nbsp;it.
      </p>

      <p class="notfound__cta" data-reveal style="--reveal-delay: 740ms">
        <span class="eyebrow notfound__cta-label">&larr;&nbsp;&nbsp;Back to</span>
        <a class="t-email link-underline notfound__home" href="/">The index</a>
      </p>
    </div>
  </div>
</main>
