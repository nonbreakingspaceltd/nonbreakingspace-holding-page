---
import Wordmark from './Wordmark.astro';

const email = 'hello@nonbreakingspace.co.uk';
---

<section class="hero">
  <div class="wrap hero__main">
    <h1 class="hero__brand">
      <span class="sr-only">Nonbreakingspace — software, interaction and graphic design studio</span>
      <span class="hero__wordmark reveal-draw" data-reveal style="--reveal-delay: 120ms">
        <Wordmark />
      </span>
    </h1>

    <div class="hero__lower">
      <p class="t-hero hero__headline" data-reveal style="--reveal-delay: 380ms">
        Software, interaction and graphic design, made with <em>passion</em>.
      </p>

      <p class="t-body hero__intro" data-reveal style="--reveal-delay: 560ms">
        Nonbreakingspace is a small Manchester studio working across front-end development,
        interaction design and brand-led web &mdash; creative, accessible and inclusive by
        design.
      </p>

      <p class="hero__cta" data-reveal style="--reveal-delay: 680ms">
        <span class="eyebrow hero__cta-label">&rarr;&nbsp;&nbsp;Start a conversation</span>
        <a class="t-email link-underline hero__email" href={`mailto:${email}`}>{email}</a>
      </p>
    </div>
  </div>

  <div class="wrap hero__foot" data-reveal style="--reveal-delay: 820ms">
    <p class="eyebrow"><span class="index">01</span>&nbsp;&mdash;&nbsp;Index</p>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
  }

  .hero__main {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(1.25rem, 2.4vw, 2.25rem);
    padding-block: clamp(1rem, 3vh, 2.25rem);
  }

  .hero__brand {
    margin: 0;
    font-weight: inherit;
  }

  /* Architectural scale, optically hung into the left margin to honour the
     wordmark's calligraphic entry stroke. Block-level so the nib-sweep mask
     reveal (.reveal-draw, in global.css) lays out correctly. */
  .hero__wordmark {
    display: block;
    width: max-content;
    max-width: 100%;
    margin-left: -0.75%;
  }
  .hero__wordmark :global(svg) {
    display: block;
    width: clamp(220px, 40vw, 540px);
    height: auto;
    color: var(--text-strong);
  }

  /* The wordmark SVG's box extends below the lettering's baseline to contain
     the descenders of "p" and ";". Pull the lower cluster up to absorb most of
     that dead-space, while still leaving a clear vertical step between the
     wordmark and the headline so they read as distinct. */
  .hero__lower {
    margin-top: clamp(-0.25rem, 0.5vw, 1rem);
  }

  .hero__headline {
    max-width: 20ch;
  }

  .hero__intro {
    /* ~60–66 character reading measure. `ch` tracks the digit width, which is
       wider than Inter's average glyph, so 50ch lands the prose around 62. */
    max-width: 50ch;
    margin-top: clamp(1rem, 2vw, 1.75rem);
    color: var(--text);
    /* Avoid a one-word widow on the last line. */
    text-wrap: pretty;
  }

  .hero__cta {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-top: clamp(1.5rem, 3vw, 2.25rem);
  }
  .hero__email {
    width: max-content;
    max-width: 100%;
    color: var(--text);
  }

  .hero__foot {
    padding-bottom: clamp(1.25rem, 3.5vh, 2.25rem);
  }

  /* Short viewports (a small or split window): stop forcing the hero to fill
     the screen exactly. Let it size to its content with comfortable padding so
     nothing is crammed, tighten the vertical rhythm, and pull the wordmark back
     so the copy keeps room to breathe. */
  @media (max-height: 860px) {
    .hero {
      min-height: 0;
    }
    .hero__main {
      justify-content: flex-start;
      gap: clamp(1rem, 2.5vh, 1.75rem);
      padding-block: clamp(5.25rem, 15vh, 8.25rem);
    }
    .hero__wordmark :global(svg) {
      width: clamp(200px, 34vw, 420px);
    }
  }
</style>
