---
import './Header.css';
// The only header — a slim editorial masthead. It does NOT stick; it scrolls
// away with the hero so the page reads as one continuous broadsheet.
//
// Carries id="top" as the page's "back to top" target (see Contact's colophon
// link). tabindex="-1" lets focus land here when that link is activated, so
// keyboard / screen-reader users resume from the top — the mirror of the
// skip link, which sends them the other way to #index.
---

<header class="site-header reveal-drop" id="top" tabindex="-1" data-reveal>
  <div class="wrap site-header__inner">
    <a class="lockup link-underline" href="/">Nonbreakingspace</a>
    <div class="site-header__end">
      <p class="eyebrow">
        Manchester, UK<time
          class="site-header__time"
          data-uk-time
          hidden></time>
      </p>
      <button
        class="theme-toggle"
        type="button"
        data-theme-toggle
        aria-label="Switch to dark theme"
        title="Switch theme"
      >
        <!-- Sun (shown in dark mode → click for light). -->
        <svg
          class="theme-toggle__icon theme-toggle__sun"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4.2"></circle>
          <path
            d="M12 2.4v2.6M12 19v2.6M4.4 4.4l1.9 1.9M17.7 17.7l1.9 1.9M2.4 12h2.6M19 12h2.6M4.4 19.6l1.9-1.9M17.7 6.3l1.9-1.9"
          ></path>
        </svg>
        <!-- Moon (shown in light mode → click for dark). -->
        <svg
          class="theme-toggle__icon theme-toggle__moon"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M20 14.4A8.2 8.2 0 1 1 9.6 4a6.6 6.6 0 0 0 10.4 10.4z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  // Live UK studio time. Progressive enhancement: the element ships hidden and
  // is only revealed once JS can render an accurate Europe/London clock.
  const el = document.querySelector<HTMLTimeElement>('[data-uk-time]');
  if (el) {
    const fmt = new Intl.DateTimeFormat('en-GB', {
      timeZone: 'Europe/London',
      hour: '2-digit',
      minute: '2-digit',
      timeZoneName: 'short',
    });
    const tick = () => {
      el.textContent = ` — ${fmt.format(new Date())}`;
      el.hidden = false;
    };
    tick();
    // Re-sync on the minute boundary, then every minute after.
    const now = new Date();
    setTimeout(() => {
      tick();
      setInterval(tick, 60_000);
    }, (60 - now.getSeconds()) * 1000);
  }

  // Theme toggle. The effective theme is the explicit choice (data-theme) if the
  // visitor has made one, otherwise the OS preference. Clicking pins the
  // opposite, persisted so the no-flash inline script in BaseLayout can apply it
  // before paint on the next load.
  const root = document.documentElement;
  const darkQuery = window.matchMedia('(prefers-color-scheme: dark)');
  const toggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');

  const isDark = () => {
    const explicit = root.getAttribute('data-theme');
    return explicit ? explicit === 'dark' : darkQuery.matches;
  };

  const syncLabel = () => {
    if (!toggle) return;
    const dark = isDark();
    toggle.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
    toggle.setAttribute('aria-pressed', String(dark));
  };

  if (toggle) {
    syncLabel();
    toggle.addEventListener('click', () => {
      const next = isDark() ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try {
        localStorage.setItem('theme', next);
      } catch {
        /* private mode — the choice just won't persist */
      }
      // Keep the address-bar / UI chrome colour in step. Drop the `media`
      // scoping so the explicit choice wins over the OS-matched defaults.
      document.querySelectorAll('meta[name="theme-color"]').forEach((meta) => {
        meta.removeAttribute('media');
        meta.setAttribute('content', next === 'dark' ? '#0b1a2a' : '#fff9ed');
      });
      syncLabel();
    });
  }

  // If the visitor is following the OS (no explicit choice), keep the label in
  // step when they change the system setting live.
  darkQuery.addEventListener('change', () => {
    if (!root.getAttribute('data-theme')) syncLabel();
  });
</script>
