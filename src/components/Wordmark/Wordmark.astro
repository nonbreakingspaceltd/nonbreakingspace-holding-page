---

{
  animated ? (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="-6 -6 2415.3 830.3"
      class:list={['nbsp-wordmark', className]}
      role={labelled ? 'img' : 'presentation'}
      aria-label={labelled ? title : undefined}
      aria-hidden={labelled ? undefined : 'true'}
      focusable="false"
    >
      {labelled && <title>{title}</title>}
      {/* Each glyph inks in solid just after its outline is traced. */}
      {GLYPHS.map((d, i) => (
        <path
          class="nbsp-solid-fill"
          d={d}
          fill="currentColor"
          style={`--draw-delay:${DRAW_DELAY_MS[i]}ms;--fill-delay:${FILL_DELAY_MS[i]}ms`}
        />
      ))}
      {/* The drawing lines: one thin pen stroke per glyph, traced in turn. */}
      {GLYPHS.map((d, i) => (
        <path
          class="nbsp-ink"
          d={d}
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          pathLength="1"
          style={`--draw-dur:${DRAW_DUR_MS[i]}ms;--draw-delay:${DRAW_DELAY_MS[i]}ms`}
        />
      ))}
    </svg>
  ) : (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 2403.3 818.3"
      class:list={['nbsp-wordmark', className]}
      role={labelled ? 'img' : 'presentation'}
      aria-label={labelled ? title : undefined}
      aria-hidden={labelled ? undefined : 'true'}
      focusable="false"
    >
      {labelled && <title>{title}</title>}
      <path fill="currentColor" d={WORDMARK_PATH}></path>
    </svg>
  )
}
