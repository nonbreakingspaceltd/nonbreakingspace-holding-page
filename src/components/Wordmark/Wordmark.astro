/**
 * The Nonbreakingspace wordmark — the studio's calligraphic monogram.
 * Drawn with `currentColor` so it inherits the surrounding text colour.
 * Decorative by default; pass a `title` to expose it as a labelled graphic.
 *
 * Reveal (opt-in via `animated`): when wrapped in `.reveal-draw` (Hero / 404 +
 * global.css), the mark DRAWS ITSELF, letter by letter, left to right — each
 * glyph's outline is traced by a thin pen line (stroke-dashoffset) and then
 * inks in solid, the next letter starting before the previous finishes so it
 * reads as handwriting. A genuine self-draw, not a wipe and not a sweeping nib.
 *
 * The single compound path is split, at authoring time, into one path per glyph
 * (`GLYPHS`, in reading order: & · n · b · s · p · ;) so each draws on its own
 * timeline. `pathLength="1"` normalises every glyph to a unit length, then each
 * glyph's stroke duration is set proportional to its TRUE length (the timing
 * arrays below) so the pen holds a near-constant velocity instead of racing the
 * big glyphs and crawling the small ones. Per-glyph duration / start / fill-trail
 * are emitted as inline custom properties (`--draw-dur`, `--draw-delay`,
 * `--fill-delay`) and consumed in global.css. Without JS, or with
 * prefers-reduced-motion: reduce, the tracing lines stay hidden and the solid
 * glyphs render immediately — the complete static logo.
 *
 * Only `animated` instances emit the per-glyph layers; everywhere else (the
 * Contact close, the brand specimens) renders the bare, static `<svg>` from the
 * undivided path.
 */
import type { Props } from './types';

const { class: className, title, animated = false } = Astro.props;
const labelled = Boolean(title);

// Self-draw timing (only consumed when `animated`). Each glyph's stroke duration
// is proportional to its true stroke length (length^0.72, normalised to ';' = 1),
// so the pen keeps a near-constant velocity across the whole word. Order matches
// GLYPHS: & · n · b · s · p · ;
//
// Weights are DERIVED from each glyph's measured path length (its getTotalLength,
// length^0.72, ';' = 1) — they are not hand-tuned. Keep them in step with the
// geometry: if a glyph path changes, re-measure and update the matching weight,
// or the pen's velocity drifts on that letter. (An earlier hand-set 'p' weight of
// 4.14 — nearly double the ~2.20 its length warrants, given 'p' is the same length
// as 'b' — made the pen crawl through 'p' and let the trailing ';' finish first.)
const DRAW_BASE_MS = 172; // single pace knob — scales the whole cadence (~150 crisp … ~215 ceremonial)
const GLYPH_WEIGHTS = [4.75, 1.95, 2.19, 1.67, 2.2, 1];
const OVERLAP = 0.62; // each glyph starts when the previous is this far drawn — a joined-up, flowing hand
// How far through each glyph's own draw the solid ink begins fading in (lower =
// sooner). The ink trails the pen: it starts before the outline is quite finished
// so the letter floods with ink *behind* the travelling line, then settles. Don't
// drop it too low — the ink shares the outline's colour, so if the fill is already
// near-opaque when the trace reaches a region, that last stretch of line is painted
// over and the outline looks like it stops short (the reason 0.45 read as broken).
// At 0.8 the fill is only ~45% up as the longest glyph's outline completes, so the
// finishing line stays visibly darker than the fill beneath it.
const FILL_TRAIL = 0.8;

const DRAW_DUR_MS = GLYPH_WEIGHTS.map((w) => Math.round(DRAW_BASE_MS * w));
// Cumulative start delays: a glyph begins OVERLAP of the way through the previous
// one, so the non-uniform gaps preserve the constant-velocity feel. With the
// weights tracking true length, completion stays in reading order on its own (a
// glyph never finishes before the one before it), so no extra ordering floor is
// needed — the pen flows unbroken from & to ;.
const DRAW_DELAY_MS = DRAW_DUR_MS.map((_, i) =>
  DRAW_DUR_MS.slice(0, i).reduce((sum, d) => sum + Math.round(d * OVERLAP), 0)
);
const FILL_DELAY_MS = DRAW_DUR_MS.map((d) => Math.round(d * FILL_TRAIL));

// Reading-order glyph outlines (absolute coords), split from WORDMARK_PATH so
// each letter can be drawn on its own staggered timeline. Their union is exactly
// WORDMARK_PATH; the counters in &, b, p stay grouped with their outer contour
// and wind opposite to it, so the default nonzero fill leaves the holes open.
