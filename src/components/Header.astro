---
// The only header — a slim editorial masthead. It does NOT stick; it scrolls
// away with the hero so the page reads as one continuous broadsheet.
---

<header class="site-header" data-reveal>
  <div class="wrap site-header__inner">
    <a class="lockup link-underline" href="/">Nonbreakingspace</a>
    <p class="eyebrow">Manchester, UK&nbsp;&mdash;&nbsp;Studio</p>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule-light);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: clamp(1rem, 2.2vh, 1.4rem);
  }
  .lockup {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-ink);
  }
  /* On the narrowest screens, drop the location tag to keep the line clean.
     30rem clears the band where the non-breaking tag could touch the lockup. */
  @media (max-width: 30rem) {
    .site-header__inner .eyebrow {
      display: none;
    }
  }
</style>
