---
// Static icons, PWA manifest and theme-colour metadata. The default theme-color
// is the ivory ground; the OS dark case and the in-page toggle (Header.astro)
// keep it in step with the active theme.
---

<!-- Icons & PWA -->
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#0b253f" />
<meta name="apple-mobile-web-app-title" content="Nonbreakingspace" />
<meta name="application-name" content="Nonbreakingspace" />
<meta name="msapplication-TileColor" content="#fff9ed" />
<meta name="theme-color" content="#fff9ed" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#0b1a2a" media="(prefers-color-scheme: dark)" />
