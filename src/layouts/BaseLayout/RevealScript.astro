---
// Reveal-on-view: subtle fade/rise, runs once per element as it scrolls into
// view. Fully JS-gated and honours prefers-reduced-motion.
---

<script>
  // Reveal-on-view: subtle fade/rise, runs once per element.
  const reveals = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduced || !('IntersectionObserver' in window)) {
    reveals.forEach((el) => el.classList.add('is-revealed'));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
    );

    // Above-the-fold elements reveal on load, NOT on scroll, and crucially are
    // NOT gated on font loading — otherwise the hero (the LCP element) can't
    // animate until the web fonts arrive, which is what inflates LCP. Two kinds:
    //  - `.reveal-drop` (the masthead) starts translated above the top edge, so
    //    it can never *intersect* — the observer would leave it stuck hidden.
    //  - `[data-reveal-eager]` (the hero) uses `.reveal-rise`, which stays fully
    //    opaque and only translates — so its text is already painted on the
    //    first frame (LCP fires immediately) and the class flip just slides it
    //    in. Neither carries an opacity fade, so firing before the fonts settle
    //    can't collapse a font-swap recalc.
    const isEager = (el: HTMLElement) =>
      el.classList.contains('reveal-drop') || el.hasAttribute('data-reveal-eager');

    // Two frames so the painted start state exists before any class flips —
    // this is a deferred module that runs before first paint, so without the
    // wait there's no "from" frame to transition out of.
    requestAnimationFrame(() =>
      requestAnimationFrame(() => {
        reveals.forEach((el) => {
          if (isEager(el)) el.classList.add('is-revealed');
        });
      })
    );

    // Below-the-fold elements fade in as they scroll into view. Defer observing
    // them until the web fonts have loaded: they finish a beat after navigation
    // and trigger a full style recalc, and revealing in that same recalc
    // collapses the before/after and kills the opacity transition.
    const observeRest = () =>
      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          reveals.forEach((el) => {
            if (!isEager(el)) observer.observe(el);
          });
        })
      );
    if (document.fonts?.status === 'loaded') {
      observeRest();
    } else {
      document.fonts.ready.then(observeRest);
    }
  }
</script>
