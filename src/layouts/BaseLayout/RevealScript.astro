---
// Reveal-on-view: subtle fade/rise, runs once per element as it scrolls into
// view. Fully JS-gated and honours prefers-reduced-motion.
---

<script>
  // Reveal-on-view: subtle fade/rise, runs once per element.
  const reveals = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduced || !('IntersectionObserver' in window)) {
    reveals.forEach((el) => el.classList.add('is-revealed'));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
    );

    // Above-the-fold elements reveal on load rather than on scroll, and — unlike
    // before — are NOT gated on document.fonts.ready. Chrome records LCP roughly
    // when the hero's fade *begins*, so starting it on load (instead of after the
    // fonts settle a beat later) is what pulls LCP in, with the same animation.
    //  - `.reveal-drop` (the masthead) starts above the top edge and can never
    //    *intersect*, so it must be classed directly.
    //  - `[data-reveal-eager]` (the hero) is the LCP region — reveal it now.
    const isEager = (el: HTMLElement) =>
      el.classList.contains('reveal-drop') || el.hasAttribute('data-reveal-eager');

    // Two frames so the hidden/translated start state is painted before any class
    // flips — this is a deferred module that runs before first paint, so without
    // the wait there's no "from" frame to transition out of.
    requestAnimationFrame(() =>
      requestAnimationFrame(() => {
        reveals.forEach((el) => {
          if (isEager(el)) el.classList.add('is-revealed');
        });
      })
    );

    // Below-the-fold elements fade in on scroll. Defer observing them until the
    // web fonts have loaded: they finish a beat after navigation and trigger a
    // full style recalc, and revealing in that same recalc collapses the
    // before/after and kills the transition.
    const observeRest = () =>
      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          reveals.forEach((el) => {
            if (!isEager(el)) observer.observe(el);
          });
        })
      );
    if (document.fonts?.status === 'loaded') {
      observeRest();
    } else {
      document.fonts.ready.then(observeRest);
    }
  }
</script>
