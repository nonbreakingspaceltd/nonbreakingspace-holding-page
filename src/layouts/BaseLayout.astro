---
import '../styles/global.css';
// Both primary faces back above-the-fold text. They're pulled in via CSS
// @font-face (global.css), so the browser only discovers them mid-parse and
// chains the requests — preload the latin subsets by URL so they start with the
// document instead. Fraunces sets the hero headline (LCP); Inter the body.
import frauncesDisplay from '@fontsource-variable/fraunces/files/fraunces-latin-opsz-normal.woff2?url';
import interBody from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title?: string;
  description?: string;
  /** Path to the page, used for the canonical + og:url. */
  path?: string;
  /** Keep the page out of search results (e.g. internal reference pages). */
  noindex?: boolean;
}

const {
  title = 'Nonbreakingspace — Software, interaction & visual design studio',
  description = 'Nonbreakingspace is a Manchester-based digital studio specialising in front-end development, interaction design and brand-led web experiences.',
  path = '/',
  noindex = false,
} = Astro.props;

const site = Astro.site ?? new URL('https://www.nonbreakingspace.co.uk');
const canonical = new URL(path, site).href;
const ogImage = new URL('/og-image.png', site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Nonbreakingspace',
  legalName: 'Nonbreakingspace Ltd',
  url: site.href,
  description,
  email: 'hello@nonbreakingspace.co.uk',
  logo: new URL('/android-chrome-512x512.png', site).href,
  identifier: {
    '@type': 'PropertyValue',
    propertyID: 'Companies House',
    value: '10833071',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'hello@nonbreakingspace.co.uk',
    contactType: 'sales',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Manchester',
    addressCountry: 'GB',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Apply the saved theme + add the `js` hook before paint, so there is no
         flash of the wrong theme and reveal styles only apply with JS. -->
    <script is:inline>
      try {
        var theme = localStorage.getItem('theme');
        if (theme === 'dark' || theme === 'light') {
          document.documentElement.setAttribute('data-theme', theme);
        }
      } catch (e) {
        /* storage blocked — fall back to the OS preference via CSS */
      }
      document.documentElement.classList.add('js');
      // Single-page site: always open at the top. Without this the browser
      // restores the previous scroll position on reload / back-forward, landing
      // a few dozen pixels down and hiding the masthead's top padding. Fragment
      // links (e.g. the skip link's #index) still scroll normally.
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <link
      rel="preload"
      href={frauncesDisplay}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href={interBody}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!-- Icons & PWA -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#0b253f" />
    <meta name="apple-mobile-web-app-title" content="Nonbreakingspace" />
    <meta name="application-name" content="Nonbreakingspace" />
    <meta name="msapplication-TileColor" content="#fff9ed" />
    <!-- Default to the ivory ground; the OS dark case and the in-page toggle
         (Header.astro) keep this in step with the active theme. -->
    <meta name="theme-color" content="#fff9ed" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b1a2a" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nonbreakingspace Ltd" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />
    <meta property="og:image:alt" content="Nonbreakingspace — software, interaction and visual design studio" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Nonbreakingspace — software, interaction and visual design studio" />

    <meta
      name="google-site-verification"
      content="DqXpRpJlp_JRGelFAi8IH_IBmNDXgoBwJ1rDsAwIqmk"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
    <Analytics />
    <SpeedInsights />
  </head>

  <body>
    <a class="skip-link" href="#index">Skip to content</a>
    <slot />

    <script>
      // Reveal-on-view: subtle fade/rise, runs once per element.
      const reveals = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduced || !('IntersectionObserver' in window)) {
        reveals.forEach((el) => el.classList.add('is-revealed'));
      } else {
        // One observer reveals each element the first time it enters view —
        // including the above-the-fold ones, which intersect on its first
        // callback (then transition with their stagger). Letting the observer
        // decide visibility keeps this off the main thread: no getBoundingClientRect
        // / innerHeight read, so nothing forces a synchronous reflow.
        //
        // Exception: a `.reveal-drop` element (the masthead) starts translated
        // fully above the top edge — it can never *intersect*, so the observer
        // would leave it stuck hidden. It's an on-load reveal by definition, so
        // class it directly instead of observing it.
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
        );
        // Defer observing so the first reveal lands cleanly. Two races to avoid:
        //  1. This is a deferred module — it runs before first paint, so the
        //     hidden/translated start state must be painted before any class
        //     flips, or there is no "from" frame to transition out of.
        //  2. The web fonts finish loading a beat after navigation and trigger a
        //     full style recalc; revealing in that same recalc collapses the
        //     before/after and kills the transition.
        // Waiting for fonts to settle, then two frames, clears both before the
        // observer can fire.
        const start = () =>
          requestAnimationFrame(() =>
            requestAnimationFrame(() => {
              reveals.forEach((el) => {
                if (el.classList.contains('reveal-drop')) {
                  el.classList.add('is-revealed');
                } else {
                  observer.observe(el);
                }
              });
            })
          );
        if (document.fonts?.status === 'loaded') {
          start();
        } else {
          document.fonts.ready.then(start);
        }
      }
    </script>
  </body>
</html>
