---
import Contact from '../components/Contact.astro';
import Header from '../components/Header.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Wordmark from '../components/Wordmark.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

// Brand guidelines — a living spec sheet for the "Measured Index" system. Every
// swatch and specimen below is driven by the same @theme tokens the site uses,
// so this page can't drift from the real design.

// The numbered index of the spec — doubles as the in-page contents nav.
const sections = [
  { index: '01', id: 'brand-idea', label: 'Brand', note: 'Positioning, the name and the promise' },
  {
    index: '02',
    id: 'foundations',
    label: 'Foundations',
    note: 'The three principles it is built on',
  },
  { index: '03', id: 'wordmark', label: 'Wordmark', note: 'The mark, clear space and misuse' },
  { index: '04', id: 'colour', label: 'Colour', note: 'Palette, semantic tokens and contrast' },
  { index: '05', id: 'typography', label: 'Typography', note: 'Two families, the scale and roles' },
  { index: '06', id: 'layout', label: 'Layout & grid', note: 'Measure, gutter, rhythm and rules' },
  { index: '07', id: 'iconography', label: 'Iconography', note: 'The few marks, drawn one way' },
  { index: '08', id: 'motion', label: 'Motion', note: 'One curve, reveals and the wipe' },
  {
    index: '09',
    id: 'voice',
    label: 'Voice & accessibility',
    note: 'How we write and the a11y floor',
  },
  {
    index: '10',
    id: 'applications',
    label: 'Applications',
    note: 'The system, applied in the world',
  },
];

const colours = [
  {
    name: 'Navy',
    token: '--color-navy',
    hex: '#0b253f',
    swatch: 'var(--color-navy)',
    role: 'Display ink and the single dark close. Also the selection + focus ring.',
    light: false,
  },
  {
    name: 'Ink',
    token: '--color-ink',
    hex: '#071a2d',
    swatch: 'var(--color-ink)',
    role: 'Body copy on the ivory ground. ≈15:1 — well clear of AA.',
    light: false,
  },
  {
    name: 'Ivory',
    token: '--color-ivory',
    hex: '#fff9ed',
    swatch: 'var(--color-ivory)',
    role: 'The page ground — a warm off-white broadsheet stock.',
    light: true,
  },
  {
    name: 'Cream',
    token: '--color-cream',
    hex: '#f4ead8',
    swatch: 'var(--color-cream)',
    role: 'The one recessed tonal band (Approach). Use sparingly.',
    light: true,
  },
  {
    name: 'Warm tan',
    token: '--color-warm',
    hex: '#c9ad94',
    swatch: 'var(--color-warm)',
    role: 'The only accent. Draws the link underline on hover/focus — never used for text.',
    light: true,
  },
  {
    name: 'Taupe — strong',
    token: '--color-muted-strong',
    hex: '#685d4e',
    swatch: 'var(--color-muted-strong)',
    role: 'Essential small text: eyebrows, labels, descriptors. ≈6:1 on ivory.',
    light: false,
  },
  {
    name: 'Taupe — quiet',
    token: '--color-muted',
    hex: '#786c5d',
    swatch: 'var(--color-muted)',
    role: 'The quietest tier — decorative indices and ticks. ≈4.9:1 on ivory.',
    light: false,
  },
];

// Measured WCAG contrast ratios for every text-on-ground pairing the system
// actually ships. Computed from the literal palette, not eyeballed.
const contrastPairs = [
  {
    fg: 'var(--color-ink)',
    bg: 'var(--color-ivory)',
    pair: 'Ink on ivory',
    sample: 'Body',
    ratio: '16.8 : 1',
    level: 'AAA',
  },
  {
    fg: 'var(--color-navy)',
    bg: 'var(--color-ivory)',
    pair: 'Navy on ivory',
    sample: 'Display',
    ratio: '14.8 : 1',
    level: 'AAA',
  },
  {
    fg: 'var(--color-muted-strong)',
    bg: 'var(--color-ivory)',
    pair: 'Taupe strong on ivory',
    sample: 'Labels',
    ratio: '6.1 : 1',
    level: 'AA',
  },
  {
    fg: 'var(--color-muted)',
    bg: 'var(--color-ivory)',
    pair: 'Taupe quiet on ivory',
    sample: 'Indices',
    ratio: '4.9 : 1',
    level: 'AA',
  },
  {
    fg: 'var(--color-ink)',
    bg: 'var(--color-cream)',
    pair: 'Ink on cream',
    sample: 'Approach',
    ratio: '14.7 : 1',
    level: 'AAA',
  },
  {
    fg: 'var(--color-ivory)',
    bg: 'var(--color-navy)',
    pair: 'Ivory on navy',
    sample: 'Close',
    ratio: '14.8 : 1',
    level: 'AAA',
  },
  {
    fg: 'var(--color-warm)',
    bg: 'var(--color-ivory)',
    pair: 'Tan on ivory',
    sample: 'Accent',
    ratio: '2.0 : 1',
    level: 'Decorative',
  },
];

// Fraunces display steps — the expressive voice. opsz (optical size) is set
// explicitly per step rather than auto.
const displayType = [
  {
    cls: 't-cta',
    name: 'CTA',
    token: '--t-cta',
    axes: 'opsz 144 · wght 360',
    size: '2.5 → 6rem',
    sample: 'Proud of it',
  },
  {
    cls: 't-hero',
    name: 'Hero',
    token: '--t-hero',
    axes: 'opsz 144 · wght 360',
    size: '2.25 → 5.75rem',
    sample: 'Made with passion',
  },
  {
    cls: 't-statement',
    name: 'Statement',
    token: '--t-statement',
    axes: 'opsz 72 · wght 360',
    size: '1.75 → 4.25rem',
    sample: 'Clarity, restraint and care',
  },
  {
    cls: 't-heading',
    name: 'Heading',
    token: '--t-heading',
    axes: 'opsz 40 · wght 380',
    size: '1.75 → 3.5rem',
    sample: 'Think · Shape · Build',
  },
  {
    cls: 't-cap',
    name: 'Capability',
    token: '--t-cap',
    axes: 'opsz 40 · wght 380',
    size: '1.5 → 2.75rem',
    sample: 'Interaction Design',
  },
  {
    cls: 't-email',
    name: 'Email',
    token: '--t-email',
    axes: 'opsz 40 · wght 380',
    size: '1.125 → 1.875rem',
    sample: 'hello@nonbreakingspace.co.uk',
  },
];

// Inter functional roles — the clean grotesque foil.
const functionalType = [
  { name: 'Body', token: '--t-body', detail: 'wght 380 · line-height 1.6 · the reading voice' },
  {
    name: 'Eyebrow',
    token: '0.75rem',
    detail: 'wght 500 · 0.22em tracking · uppercase — the only caps',
  },
  {
    name: 'Meta label',
    token: '0.8125rem',
    detail: 'wght 500 · 0.12em tracking · uppercase descriptors',
  },
  { name: 'Row index', token: '0.75rem', detail: 'tabular lining numerals — two-digit foliation' },
  { name: 'Legal', token: '0.6875rem', detail: 'line-height 1.5 · colophon fine print' },
];

const layoutTokens = [
  { token: '--gutter', value: 'clamp(1.5rem, 6vw, 9rem)', note: 'Page inline padding (.wrap).' },
  { token: '--content-max', value: '1280px', note: 'Maximum measure for the centred column.' },
  {
    token: '--pad-section',
    value: 'clamp(5rem, 12vh, 9rem)',
    note: 'Default vertical section rhythm.',
  },
  {
    token: '--pad-statement',
    value: 'clamp(7rem, 16vh, 13rem)',
    note: 'The breathing room around the statement.',
  },
  { token: '--pad-contact', value: 'clamp(6rem, 14vh, 11rem)', note: 'The dark close.' },
  {
    token: '--grid-gap',
    value: 'clamp(1.5rem, 4vw, 3.5rem)',
    note: 'Primary multi-column grid gap.',
  },
  {
    token: '--grid-gap-tight',
    value: 'clamp(1.5rem, 3vw, 2.5rem)',
    note: 'Card galleries (misuse, swatches).',
  },
  { token: '--stack-gap', value: 'clamp(1rem, 2.5vh, 1.5rem)', note: 'Vertical figure-stack gap.' },
  {
    token: '--rule-light',
    value: 'rgb(7 26 45 / 0.12)',
    note: 'Hairline on ivory — 1px borders, never shadows.',
  },
  { token: '--rule-dark', value: 'rgb(255 249 237 / 0.15)', note: 'Hairline on navy.' },
];

// Vertical-rhythm steps, drawn to scale from their MAX clamp value (px).
const rhythmScale = [
  { name: 'Statement', token: '--pad-statement', label: '7 → 13rem', max: 208 },
  { name: 'Dark close', token: '--pad-contact', label: '6 → 11rem', max: 176 },
  { name: 'Section', token: '--pad-section', label: '5 → 9rem', max: 144 },
];
const rhythmMax = 208;

// Wordmark misuse — each renders the real mark under a forbidden treatment.
const misuses = [
  { mod: 'stretch', cap: 'Don’t stretch the proportions' },
  { mod: 'condense', cap: 'Don’t condense or squeeze it' },
  { mod: 'rotate', cap: 'Don’t rotate or set it at an angle' },
  { mod: 'recolour', cap: 'Don’t recolour outside navy / ivory' },
  { mod: 'effect', cap: 'Don’t add shadows, outlines or effects' },
  { mod: 'busy', cap: 'Don’t place it on busy or low-contrast grounds' },
];

// Typographic connective marks — the system is near icon-free, so these glyphs
// (set in Fraunces) do much of the work icons would elsewhere.
const connectives = [
  { glyph: '&', name: 'Ampersand', role: 'The wordmark’s hand — Fraunces’ characterful form.' },
  { glyph: '—', name: 'Em dash', role: 'The studio aside; the page’s main connective.' },
  { glyph: '·', name: 'Middle dot', role: 'Separates inline meta and the legal line.' },
  { glyph: '→', name: 'Arrow', role: 'Change and direction — “0 → 100%”.' },
];

const motionTokens = [
  {
    name: 'Easing',
    detail: 'cubic-bezier(0.22, 1, 0.36, 1) — every transition uses this single curve.',
  },
  { name: 'Reveal', detail: 'Fade + 1.25rem rise over 0.7s, once per element as it scrolls in.' },
  {
    name: 'Wipe',
    detail: 'The wordmark performs a single left-to-right clip-path wipe over 0.9s — written once.',
  },
  {
    name: 'Restraint',
    detail: 'All motion is JS-gated and honours prefers-reduced-motion: reduce.',
  },
];

// Tone of voice — preferred phrasing against what we avoid.
const lexicon = [
  { say: 'We build', not: 'We deliver solutions', why: 'Plain verbs over corporate nouns.' },
  { say: 'For everyone', not: 'For users', why: 'People, not segments — where a person will do.' },
  {
    say: 'Accessible by default',
    not: 'Accessibility-first™',
    why: 'No buzzwords, no trademarks.',
  },
  { say: 'We read everything', not: 'We’ll circle back', why: 'Human and direct; we mean it.' },
  { say: 'A small studio', not: 'A boutique agency', why: 'Honest about our scale.' },
];

// Colophon — credits for the artefact itself, in the broadsheet tradition.
const colophon = [
  { term: 'Display', detail: 'Fraunces — variable optical size, by Undercase Type.' },
  { term: 'Text', detail: 'Inter — variable, by Rasmus Andersson.' },
  { term: 'Built with', detail: 'Astro & Tailwind CSS, CSS-first.' },
  { term: 'Fonts', detail: 'Self-hosted woff2 subsets — no external requests.' },
  { term: 'Hosting', detail: 'Vercel, with privacy-light analytics.' },
  { term: 'Source of truth', detail: 'Generated from the same @theme tokens the site ships.' },
];
---

<BaseLayout
  title="Brand Guidelines — Nonbreakingspace"
  description="The Measured Index — Nonbreakingspace's brand system: positioning, wordmark, palette, typography, layout, iconography, motion, voice and applications."
  path="/brand"
  mainId="brand"
>
  <Header />

  <main id="brand" tabindex="-1">
    <!-- Title block -->
    <section class="brand-hero">
      <div class="wrap">
        <p class="eyebrow brand-hero__kicker" data-reveal>Brand Guidelines &mdash; The Measured Index</p>
        <h1 class="t-hero brand-hero__title" data-reveal style="--reveal-delay: 120ms">
          One system, <em>measured</em>.
        </h1>
        <p class="t-body brand-hero__lede" data-reveal style="--reveal-delay: 260ms">
          A warm-ivory editorial broadsheet where type does almost everything and restraint is
          the device. Two families, one accent, hairline rules. Everything on this page is driven
          by the same design tokens the site ships &mdash; change a token, change the brand.
        </p>
      </div>
    </section>

    <!-- The index — contents nav -->
    <nav class="contents" aria-label="Section index">
      <div class="wrap">
        <p class="eyebrow contents__kicker" data-reveal>The index &mdash; ten sections</p>
        <ol class="contents__list">
          {
            sections.map((s, i) => (
              <li class="contents__item" data-reveal style={`--reveal-delay: ${i * 35}ms`}>
                <a class="contents__link" href={`#${s.id}`}>
                  <span class="contents__index row-index" aria-hidden="true">{s.index}</span>
                  <span class="contents__label">{s.label}</span>
                  <span class="contents__note meta-label">{s.note}</span>
                </a>
              </li>
            ))
          }
        </ol>
      </div>
    </nav>

    <!-- 01 — Brand -->
    <section id="brand-idea" class="band" aria-labelledby="brand-idea-label">
      <div class="wrap">
        <SectionLabel index="01" label="Brand" id="brand-idea-label" />
        <p class="t-statement brand-idea__line" data-reveal>
          Systems that work for <em>everyone</em> &mdash; not just the few.
        </p>
        <p class="t-body brand-idea__lede" data-reveal style="--reveal-delay: 120ms">
          Nonbreakingspace is a small Manchester studio working across front-end development,
          interaction design and brand-led web. The promise is constant: creative, accessible
          and inclusive by design, so what we build works for everyone.
        </p>

        <div class="brand-idea__split">
          <article data-reveal>
            <h3 class="meta-label subhead">The name</h3>
            <p class="t-body brand-idea__copy">
              A non-breaking space (<code class="token">&amp;nbsp;</code>) is the invisible
              character that stops words breaking apart at the end of a line. It is small,
              unseen, and quietly holds things together &mdash; which is exactly the work. The
              studio is named for the detail most people never notice, but everyone feels.
            </p>
          </article>
          <article data-reveal style="--reveal-delay: 120ms">
            <h3 class="meta-label subhead">The promise</h3>
            <ul class="promise">
              <li>Considered, never decorated.</li>
              <li>Accessible to the floor, and past it.</li>
              <li>Built to last; made to adapt.</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <!-- 02 — Foundations -->
    <section id="foundations" class="band" aria-labelledby="foundations-label">
      <div class="wrap">
        <SectionLabel index="02" label="Foundations" id="foundations-label" />
        <div class="principles">
          <article class="principle" data-reveal>
            <h3 class="t-heading">Type leads the way</h3>
            <p class="t-body principle__copy">The page is set, not decorated. Fraunces leads; Inter does the functional work.</p>
          </article>
          <article class="principle" data-reveal style="--reveal-delay: 80ms">
            <h3 class="t-heading">Restraint is the device</h3>
            <p class="t-body principle__copy">One accent, one dark close, one italic gesture per view &mdash; nothing unearned stays.</p>
          </article>
          <article class="principle" data-reveal style="--reveal-delay: 160ms">
            <h3 class="t-heading">Edges earn their keep</h3>
            <p class="t-body principle__copy">A hairline appears only where it does work &mdash; structure comes from space, never cards or containers.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- 03 — Wordmark -->
    <section id="wordmark" class="band" aria-labelledby="wordmark-label">
      <div class="wrap">
        <SectionLabel index="03" label="Wordmark" id="wordmark-label" />
        <div class="mark-grid">
          <figure class="mark mark--light" data-reveal>
            <span class="mark__art"><Wordmark title="Nonbreakingspace wordmark" /></span>
            <figcaption class="meta-label">On ivory &mdash; navy ink</figcaption>
          </figure>
          <figure class="mark mark--dark on-navy" data-reveal style="--reveal-delay: 100ms">
            <span class="mark__art mark__art--invert"><Wordmark /></span>
            <figcaption class="meta-label">On navy &mdash; ivory ink</figcaption>
          </figure>
        </div>

        <h3 class="meta-label subhead subhead--spaced">Clear space &amp; minimum size</h3>
        <div class="construction">
          <figure class="clearspace" data-reveal>
            <div class="clearspace__stage" aria-hidden="true">
              <div class="clearspace__frame">
                <span class="clearspace__unit">X</span>
                <span class="clearspace__bound">
                  <span class="mark__art clearspace__mark"><Wordmark /></span>
                </span>
              </div>
            </div>
            <figcaption class="figcap">
              Keep clear space of at least <strong>X</strong> on every side, where X is the height
              of the ampersand bowl. Nothing &mdash; type, rule or edge &mdash; enters the zone.
            </figcaption>
          </figure>
          <figure class="minsize" data-reveal style="--reveal-delay: 100ms">
            <div class="minsize__stage" aria-hidden="true">
              <span class="mark__art minsize__mark"><Wordmark /></span>
              <span class="minsize__tag meta-label">120px</span>
            </div>
            <figcaption class="figcap">
              Minimum <strong>120px</strong> wide on screen. Below this the calligraphic entry
              stroke thins and the counters begin to close. It is one continuous path &mdash; never
              rebuild it from separate letters.
            </figcaption>
          </figure>
        </div>

        <div class="notes">
          <div class="note" data-reveal>
            <h3 class="meta-label note__head">Do</h3>
            <ul class="t-body note__list">
              <li>Draw it in <code class="token">currentColor</code> so it inherits the text colour.</li>
              <li>Give it clear space of at least the height of the ampersand bowl on every side.</li>
              <li>Let it run the single written-once wipe on first view; static everywhere after.</li>
            </ul>
          </div>
          <div class="note" data-reveal style="--reveal-delay: 100ms">
            <h3 class="meta-label note__head">Don't</h3>
            <ul class="t-body note__list">
              <li>Recolour it outside navy / ivory, or place it on a busy ground.</li>
              <li>Stretch, rotate, outline or add effects &mdash; it is a single calligraphic path.</li>
              <li>Set it below ~120px wide, where the entry stroke loses its weight.</li>
            </ul>
          </div>
        </div>

        <h3 class="meta-label subhead subhead--spaced">Misuse</h3>
        <ul class="misuse">
          {
            misuses.map((m, i) => (
              <li class="misuse__item" data-reveal style={`--reveal-delay: ${i * 40}ms`}>
                <span class:list={['misuse__stage', `misuse--${m.mod}`]} aria-hidden="true">
                  <span class="mark__art misuse__mark"><Wordmark /></span>
                </span>
                <p class="misuse__cap">
                  <span class="misuse__x" aria-hidden="true">&times;</span>{m.cap}
                </p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- 04 — Colour -->
    <section id="colour" class="band" aria-labelledby="colour-label">
      <div class="wrap">
        <SectionLabel index="04" label="Colour" id="colour-label" />
        <ul class="swatches">
          {
            colours.map((c, i) => (
              <li class="swatch" data-reveal style={`--reveal-delay: ${i * 50}ms`}>
                <span
                  class:list={['swatch__chip', { 'swatch__chip--light': c.light }]}
                  style={`background:${c.swatch}`}
                  aria-hidden="true"
                />
                <div class="swatch__meta">
                  <p class="swatch__name t-body">{c.name}</p>
                  <p class="token swatch__hex">{c.hex}</p>
                  <p class="token swatch__token">{c.token}</p>
                  <p class="swatch__role">{c.role}</p>
                </div>
              </li>
            ))
          }
        </ul>

        <h3 class="meta-label subhead subhead--spaced">Semantic tokens &amp; themes</h3>
        <p class="t-body colour-note" data-reveal>
          Components reference <em>role</em> tokens &mdash; <code class="token">--surface</code>,
          <code class="token">--text</code>, <code class="token">--text-strong</code>,
          <code class="token">--accent</code>, <code class="token">--rule</code> and friends
          &mdash; never the raw palette above. The default Light theme maps them onto these
          swatches; Dark re-points them to a warm-light-on-deep-navy set of the same family.
          Dark follows the operating system by default, with a masthead toggle to override that
          is remembered across visits.
        </p>

        <h3 class="meta-label subhead subhead--spaced">Contrast</h3>
        <p class="t-body colour-note" data-reveal>
          Measured ratios for every text-on-ground pairing the system ships. AA needs 4.5:1 for
          body text; AAA, 7:1. The tan accent clears neither &mdash; which is exactly why it only
          ever draws a line, never sets type.
        </p>
        <ul class="contrast">
          {
            contrastPairs.map((c, i) => (
              <li class="contrast-row" data-reveal style={`--reveal-delay: ${i * 40}ms`}>
                <span class="contrast__plate" style={`background:${c.bg};color:${c.fg}`} aria-hidden="true">{c.sample}</span>
                <span class="contrast__pair t-body">{c.pair}</span>
                <span class="token contrast__ratio">{c.ratio}</span>
                <span class="contrast__level meta-label">{c.level}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- 05 — Typography -->
    <section id="typography" class="band" aria-labelledby="type-label">
      <div class="wrap">
        <SectionLabel index="05" label="Typography" id="type-label" />

        <div class="families">
          <article class="family" data-reveal>
            <p class="family__specimen t-display" aria-hidden="true" style="font-size: clamp(3rem, 8vw, 5.5rem); line-height: 0.9;">Aa</p>
            <h3 class="t-cap">Fraunces</h3>
            <p class="t-body">The expressive serif. Variable optical-size (opsz) axis, set
              explicitly per step. Italic is reserved for a single accent word per view.</p>
          </article>
          <article class="family" data-reveal style="--reveal-delay: 100ms">
            <p class="family__specimen" aria-hidden="true" style="font-family: var(--font-sans); font-weight: 380; font-size: clamp(3rem, 8vw, 5.5rem); line-height: 0.9; color: var(--text);">Aa</p>
            <h3 class="t-cap">Inter</h3>
            <p class="t-body">The clean grotesque foil. Body copy, eyebrows, labels and every
              functional role. Tabular lining numerals for indices.</p>
          </article>
        </div>

        <h3 class="meta-label subhead">Display scale &mdash; Fraunces</h3>
        <ul class="specimens">
          {
            displayType.map((t, i) => (
              <li class="specimen" data-reveal style={`--reveal-delay: ${i * 40}ms`}>
                <p class={`specimen__sample ${t.cls}`}>{t.sample}</p>
                <dl class="specimen__meta">
                  <div><dt class="meta-label">Class</dt><dd class="token">.{t.cls}</dd></div>
                  <div><dt class="meta-label">Token</dt><dd class="token">{t.token}</dd></div>
                  <div><dt class="meta-label">Axes</dt><dd class="token">{t.axes}</dd></div>
                  <div><dt class="meta-label">Size</dt><dd class="token">{t.size}</dd></div>
                </dl>
              </li>
            ))
          }
        </ul>

        <h3 class="meta-label subhead">Functional roles &mdash; Inter</h3>
        <ul class="roles">
          {
            functionalType.map((t, i) => (
              <li class="role" data-reveal style={`--reveal-delay: ${i * 40}ms`}>
                <p class="role__name t-body">{t.name}</p>
                <p class="token role__token">{t.token}</p>
                <p class="role__detail">{t.detail}</p>
              </li>
            ))
          }
        </ul>

        <h3 class="meta-label subhead">Links</h3>
        <div class="link-spec" data-reveal>
          <p class="link-spec__sample t-body">
            Inline links carry a <a class="link-underline" href="#colour">drawn tan underline</a> that
            wipes in on hover and keyboard focus &mdash; the page&rsquo;s only use of the accent.
          </p>
          <dl class="specimen__meta">
            <div><dt class="meta-label">Class</dt><dd class="token">.link-underline</dd></div>
            <div><dt class="meta-label">Colour</dt><dd class="token">--accent</dd></div>
            <div><dt class="meta-label">Trigger</dt><dd class="token">:hover, :focus-visible</dd></div>
            <div><dt class="meta-label">Motion</dt><dd class="token">background-size 0&rarr;100% &middot; 0.32s</dd></div>
          </dl>
        </div>
      </div>
    </section>

    <!-- 06 — Layout & grid -->
    <section id="layout" class="band" aria-labelledby="layout-label">
      <div class="wrap">
        <SectionLabel index="06" label="Layout &amp; grid" id="layout-label" />

        <h3 class="meta-label subhead">The measure</h3>
        <figure class="measure" data-reveal>
          <div class="measure__frame" aria-hidden="true">
            <span class="measure__edge"><span>Gutter</span></span>
            <div class="measure__col">
              <span class="meta-label measure__cap">Content &mdash; max 1280px</span>
            </div>
            <span class="measure__edge"><span>Gutter</span></span>
          </div>
          <figcaption class="measure__note">
            Every section centres one column capped at <code class="token">--content-max</code>,
            with <code class="token">--gutter</code> inline padding that grows from 1.5rem to 9rem
            with the viewport. There is no multi-column page grid &mdash; structure comes from the
            measure and the hairlines.
          </figcaption>
        </figure>

        <h3 class="meta-label subhead">Vertical rhythm</h3>
        <ul class="rhythm" data-reveal>
          {
            rhythmScale.map((r) => (
              <li class="rhythm__row">
                <span class="rhythm__name t-body">{r.name}</span>
                <span class="rhythm__track">
                  <span class="rhythm__bar" style={`width:${(r.max / rhythmMax) * 100}%`} aria-hidden="true" />
                </span>
                <span class="token rhythm__val">{r.label}</span>
              </li>
            ))
          }
        </ul>
        <p class="figcap rhythm__note">Shown at each step&rsquo;s maximum. All vertical space resolves from this short scale of clamps.</p>

        <h3 class="meta-label subhead">Tokens</h3>
        <ul class="tokens">
          {
            layoutTokens.map((t, i) => (
              <li class="token-row" data-reveal style={`--reveal-delay: ${i * 30}ms`}>
                <p class="token token-row__name">{t.token}</p>
                <p class="token token-row__value">{t.value}</p>
                <p class="token-row__note">{t.note}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- 07 — Iconography -->
    <section id="iconography" class="band" aria-labelledby="icon-label">
      <div class="wrap">
        <SectionLabel index="07" label="Iconography" id="icon-label" />
        <p class="t-body icon-lede" data-reveal>
          The system is almost icon-free &mdash; type and hairlines carry the meaning. The few marks
          that exist share one hand: a 24px field, a single hairline weight, round caps and joins,
          drawn in <code class="token">currentColor</code> so they inherit the surrounding text.
        </p>

        <ul class="icon-set">
          <li class="icon" data-reveal>
            <span class="icon__art">
              <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
                <circle cx="12" cy="12" r="4.2"></circle>
                <path d="M12 2.4v2.6M12 19v2.6M4.4 4.4l1.9 1.9M17.7 17.7l1.9 1.9M2.4 12h2.6M19 12h2.6M4.4 19.6l1.9-1.9M17.7 6.3l1.9-1.9"></path>
              </svg>
            </span>
            <figcaption class="meta-label">Sun &mdash; switch to light</figcaption>
          </li>
          <li class="icon" data-reveal style="--reveal-delay: 80ms">
            <span class="icon__art">
              <svg viewBox="0 0 24 24" width="40" height="40" fill="currentColor" aria-hidden="true">
                <path d="M20 14.4A8.2 8.2 0 1 1 9.6 4a6.6 6.6 0 0 0 10.4 10.4z"></path>
              </svg>
            </span>
            <figcaption class="meta-label">Moon &mdash; switch to dark</figcaption>
          </li>
        </ul>

        <dl class="specimen__meta icon-spec" data-reveal>
          <div><dt class="meta-label">Field</dt><dd class="token">24 × 24</dd></div>
          <div><dt class="meta-label">Stroke</dt><dd class="token">1.6px</dd></div>
          <div><dt class="meta-label">Caps &amp; joins</dt><dd class="token">round</dd></div>
          <div><dt class="meta-label">Colour</dt><dd class="token">currentColor</dd></div>
        </dl>

        <h3 class="meta-label subhead subhead--spaced">Connective marks</h3>
        <ul class="connectives">
          {
            connectives.map((m, i) => (
              <li class="connective" data-reveal style={`--reveal-delay: ${i * 50}ms`}>
                <span class="connective__glyph t-display" aria-hidden="true">{m.glyph}</span>
                <span class="connective__text">
                  <span class="connective__name t-body">{m.name}</span>
                  <span class="connective__role">{m.role}</span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- 08 — Motion -->
    <section id="motion" class="band" aria-labelledby="motion-label">
      <div class="wrap">
        <SectionLabel index="08" label="Motion" id="motion-label" />
        <ul class="motion">
          {
            motionTokens.map((m, i) => (
              <li class="motion__item" data-reveal style={`--reveal-delay: ${i * 50}ms`}>
                <h3 class="t-cap motion__name">{m.name}</h3>
                <p class="t-body">{m.detail}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- 09 — Voice & accessibility -->
    <section id="voice" class="band" aria-labelledby="voice-label">
      <div class="wrap">
        <SectionLabel index="09" label="Voice &amp; accessibility" id="voice-label" />
        <div class="voice">
          <div class="voice__col" data-reveal>
            <h3 class="t-cap voice__head">Voice</h3>
            <p class="t-body">Plain, considered, British. Short declarative lines; one idea each.
              Sentence case everywhere except the tracked eyebrow. Never breezy, never salesy
              &mdash; the studio reads everything and means it.</p>
          </div>
          <div class="voice__col" data-reveal style="--reveal-delay: 100ms">
            <h3 class="t-cap voice__head">Accessibility</h3>
            <p class="t-body">WCAG 2.2 AA is the floor, not the goal. All text clears 4.5:1.
              Motion is gated behind <code class="token">prefers-reduced-motion</code>,
              focus is always visible, and the wordmark is decorative unless labelled.</p>
          </div>
        </div>

        <h3 class="meta-label subhead subhead--spaced">Lexicon</h3>
        <ul class="lexicon">
          {
            lexicon.map((l, i) => (
              <li class="lexicon__row" data-reveal style={`--reveal-delay: ${i * 40}ms`}>
                <span class="lexicon__say t-body">{l.say}</span>
                <span class="lexicon__not">not &ldquo;{l.not}&rdquo;</span>
                <span class="lexicon__why">{l.why}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- 10 — Applications -->
    <section id="applications" class="band" aria-labelledby="apps-label">
      <div class="wrap">
        <SectionLabel index="10" label="Applications" id="apps-label" />
        <p class="t-body apps-lede" data-reveal>
          Where the system meets the world. The same tokens and the one mark, applied consistently
          across every touchpoint &mdash; from the address bar to the share card.
        </p>

        <div class="apps-grid">
          <figure class="app" data-reveal>
            <span class="app__stage app__stage--icon">
              <img class="app__icon" src="/android-chrome-512x512.png" alt="" width="104" height="104" loading="lazy" />
            </span>
            <figcaption class="figcap">App icon &mdash; the ampersand monogram, square-cropped for home screens, favicons and PWA installs.</figcaption>
          </figure>

          <figure class="app" data-reveal style="--reveal-delay: 100ms">
            <span class="app__stage app__stage--masthead">
              <span class="app__lockup">Nonbreakingspace</span>
              <span class="app__loc meta-label">Manchester, UK &mdash; 14:07 BST</span>
            </span>
            <figcaption class="figcap">Masthead lockup &mdash; the tracked uppercase wordmark with the live location tag, as it runs in the header.</figcaption>
          </figure>
        </div>

        <figure class="app app--wide" data-reveal>
          <span class="app__stage app__stage--og">
            <img class="app__og" src="/og-image.png" alt="" width="2400" height="1260" loading="lazy" />
          </span>
          <figcaption class="figcap">Share card &mdash; the Open Graph image shown when a link is posted. 2400 × 1260, built on the ivory ground.</figcaption>
        </figure>

        <figure class="app app--wide" data-reveal style="--reveal-delay: 100ms">
          <span class="app__stage app__stage--card on-navy">
            <span class="mark__art mark__art--invert card__mark"><Wordmark /></span>
            <span class="card__foot">
              <span class="meta-label card__role">Software &amp; design studio</span>
              <span class="legal card__line">hello@nonbreakingspace.co.uk&nbsp;&middot;&nbsp;Manchester, UK</span>
            </span>
          </span>
          <figcaption class="figcap">Stationery &mdash; the mark, ivory on navy, with the address set in the functional roles. Derived entirely from the tokens above.</figcaption>
        </figure>
      </div>
    </section>

    <!-- Colophon — the close of the spec -->
    <section id="colophon" class="band colophon" aria-labelledby="colophon-label">
      <div class="wrap">
        <p class="eyebrow colophon__kicker" id="colophon-label" data-reveal>Colophon</p>
        <div class="colophon__grid">
          <p class="t-statement colophon__line" data-reveal>
            Set in <em>Fraunces</em> &amp; Inter. Built from tokens.
          </p>
          <dl class="colophon__facts" data-reveal style="--reveal-delay: 120ms">
            {
              colophon.map((c) => (
                <div>
                  <dt class="meta-label">{c.term}</dt>
                  <dd>{c.detail}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>
    </section>
  </main>

  <!-- Shared footer — identical to the index page. -->
  <Contact />
</BaseLayout>

<style>
  main:focus {
    outline: none;
  }

  /* Mono "spec sheet" voice for code-like tokens. */
  .token {
    font-family: ui-monospace, 'SF Mono', SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.8125rem;
    letter-spacing: 0;
    color: var(--text-muted-strong);
  }
  code.token {
    font-size: 0.85em;
  }

  /* Sentence-case caption voice for figures (distinct from the uppercase meta-label). */
  .figcap {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--text-muted-strong);
    text-wrap: pretty;
    max-width: 44ch;
  }
  .figcap strong {
    color: var(--text-strong);
    font-weight: 600;
  }

  /* ---- Title block ---- */
  .brand-hero {
    padding-block: clamp(3.5rem, 9vh, 7rem) clamp(2.5rem, 6vh, 4.5rem);
  }
  .brand-hero__kicker {
    margin-bottom: clamp(1.5rem, 4vh, 2.5rem);
  }
  .brand-hero__title {
    max-width: 18ch;
  }
  .brand-hero__lede {
    max-width: 52ch;
    margin-top: clamp(1.5rem, 4vh, 2.5rem);
    color: var(--text);
    text-wrap: pretty;
  }

  /* ---- The index — contents nav ---- */
  .contents {
    padding-block: clamp(2.5rem, 6vh, 4.5rem);
    border-top: 1px solid var(--rule);
  }
  .contents__kicker {
    margin-bottom: clamp(1.5rem, 4vh, 2.5rem);
  }
  .contents__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .contents__item {
    border-top: 1px solid var(--rule);
    transition: border-color 0.24s var(--ease-out-soft);
  }
  .contents__item:first-child {
    border-top: 0;
  }
  .contents__link {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    column-gap: clamp(0.85rem, 2vw, 1.75rem);
    padding-block: clamp(0.85rem, 2vh, 1.35rem);
    color: var(--text-strong);
  }
  .contents__label {
    font-family: var(--font-display);
    font-optical-sizing: none;
    font-variation-settings: 'opsz' 40, 'wght' 380;
    font-size: clamp(1.25rem, 0.95rem + 1.2vw, 1.75rem);
    line-height: 1;
    letter-spacing: -0.01em;
    transition: transform 0.24s var(--ease-out-soft);
  }
  .contents__note {
    justify-self: end;
    text-align: right;
    color: var(--text-muted-strong);
    transition: transform 0.24s var(--ease-out-soft);
  }
  @media (hover: hover) {
    .contents__item:hover {
      border-color: var(--accent);
    }
    .contents__link:hover .contents__label {
      transform: translateX(8px);
    }
    .contents__link:hover .contents__note {
      transform: translateX(6px);
    }
  }

  /* ---- Section shell ---- */
  .band {
    padding-block: var(--pad-section);
    border-top: 1px solid var(--rule);
  }

  /* ---- 01 Brand ---- */
  .brand-idea__line {
    max-width: 20ch;
  }
  .brand-idea__line em {
    font-style: italic;
  }
  .brand-idea__lede {
    max-width: 58ch;
    margin-top: clamp(1.5rem, 4vh, 2.5rem);
    color: var(--text);
    text-wrap: pretty;
  }
  .brand-idea__split {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap);
    margin-top: clamp(3rem, 7vh, 5rem);
  }
  .brand-idea__copy {
    max-width: 44ch;
    color: var(--text);
    text-wrap: pretty;
  }
  .promise {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 36ch;
  }
  .promise li {
    position: relative;
    padding-left: 1.25rem;
    padding-block: clamp(0.55rem, 1.4vh, 0.85rem);
    color: var(--text);
    border-top: 1px solid var(--rule);
    font-family: var(--font-display);
    font-optical-sizing: none;
    font-variation-settings: 'opsz' 40, 'wght' 380;
    font-size: clamp(1.125rem, 0.95rem + 0.8vw, 1.5rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--text-strong);
  }
  .promise li:first-child {
    border-top: 0;
  }
  .promise li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.35em;
    width: 0.5rem;
    height: 1px;
    background: var(--accent);
  }

  /* ---- 02 Foundations ---- */
  .principles {
    --principles-gap: clamp(2rem, 4vw, 4rem);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    column-gap: var(--principles-gap);
    /* Large gap only separates principles when they stack on narrow screens. */
    row-gap: clamp(2.5rem, 6vh, 4rem);
  }
  /* Subgrid keeps heading / copy aligned across columns regardless of
     how the headings wrap; the vertical gutter rule frames without boxing. */
  .principle {
    position: relative;
    grid-row: span 2;
    display: grid;
    grid-template-rows: subgrid;
    row-gap: clamp(0.85rem, 2vh, 1.25rem);
  }
  .principle + .principle::before {
    content: '';
    position: absolute;
    inset-block: 0;
    left: calc(-0.5 * var(--principles-gap));
    border-left: 1px solid var(--rule);
  }
  .principle__copy {
    max-width: 26ch;
    color: var(--text);
    text-wrap: pretty;
  }

  /* ---- 03 Wordmark ---- */
  .mark-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.25rem, 3vw, 2rem);
  }
  .mark {
    margin: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--stack-gap);
    padding: clamp(1.75rem, 4vw, 3rem);
    /* Shared example-card ratio so every framed image reads as one set. */
    aspect-ratio: 16 / 9;
    border: 1px solid var(--rule);
  }
  .mark--dark {
    background: var(--surface-contrast);
    border-color: transparent;
  }
  .mark--dark .meta-label {
    color: color-mix(in srgb, var(--text-on-contrast) 70%, transparent);
  }
  .mark__art :global(svg) {
    display: block;
    width: clamp(160px, 30vw, 300px);
    height: auto;
    color: var(--text-strong);
  }
  .mark__art--invert :global(svg) {
    color: var(--text-on-contrast);
  }

  /* Clear space + minimum size */
  .construction {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap);
  }
  .clearspace,
  .minsize {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--stack-gap);
  }
  /* Outer card — the plain framed canvas (matches the wordmark example cards),
     centring the construct so the pair balances with the min-size card. */
  .clearspace__stage {
    display: grid;
    place-items: center;
    padding: clamp(1.75rem, 4vw, 3rem);
    /* Shared example-card ratio (see .mark). */
    aspect-ratio: 16 / 9;
    border: 1px solid var(--rule);
  }
  /* The clear-space construct: shrink-wrapped to the mark plus one X of clear
     space on every side, so the tinted band IS the keep-clear zone the corner
     unit measures. */
  .clearspace__frame {
    position: relative;
    width: max-content;
    max-width: 100%;
    padding: var(--cs-x, clamp(1.5rem, 4vw, 2.75rem));
    background: var(--surface-recessed);
  }
  /* The unit module that defines the margin, pinned into one corner. */
  .clearspace__unit {
    position: absolute;
    top: 0;
    left: 0;
    width: var(--cs-x, clamp(1.5rem, 4vw, 2.75rem));
    height: var(--cs-x, clamp(1.5rem, 4vw, 2.75rem));
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--accent) 22%, transparent);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--text-muted-strong);
  }
  /* The dashed line hugs the mark — it IS the mark's bounding box. The mark
     sits on the page ground so it reads as distinct from the tinted clear band. */
  .clearspace__bound {
    display: block;
    padding: 0;
    border: 1px dashed color-mix(in srgb, var(--text-muted) 55%, transparent);
    background: var(--surface);
  }
  .clearspace__mark {
    display: block;
  }
  .clearspace__mark :global(svg) {
    display: block;
    width: clamp(180px, 40vw, 300px);
  }
  /* Matching outer card — same plain frame as the clear-space stage, centring
     the dashed 120px mark + label. */
  .minsize__stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    padding: clamp(1.75rem, 4vw, 3rem);
    /* Shared example-card ratio (see .mark). */
    aspect-ratio: 16 / 9;
    border: 1px solid var(--rule);
  }
  /* The dashed line wraps the 120px mark itself — it IS the 120px width the
     label calls out; the "120PX" tag sits outside it, below. */
  .minsize__mark {
    display: block;
    width: max-content;
    border: 1px dashed color-mix(in srgb, var(--text-muted) 55%, transparent);
  }
  .minsize__mark :global(svg) {
    display: block;
    width: 120px;
  }
  .minsize__tag {
    color: var(--text-muted);
  }

  .notes {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap);
    margin-top: clamp(2.5rem, 6vh, 4rem);
  }
  .note__head {
    margin-bottom: clamp(0.85rem, 2vh, 1.25rem);
  }
  .note__list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 40ch;
  }
  .note__list li {
    position: relative;
    padding-left: 1.25rem;
    color: var(--text);
  }
  .note__list li + li {
    margin-top: 0.65rem;
  }
  .note__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 0.5rem;
    height: 1px;
    background: var(--accent);
  }

  /* Misuse gallery — the real mark under forbidden treatments. */
  .misuse {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--grid-gap-tight);
  }
  .misuse__item {
    display: flex;
    flex-direction: column;
    gap: clamp(0.85rem, 2vh, 1.15rem);
  }
  .misuse__stage {
    display: grid;
    place-items: center;
    min-height: clamp(7rem, 16vh, 9rem);
    padding: 1.25rem;
    overflow: hidden;
    border: 1px solid var(--rule);
    background: var(--surface);
  }
  .misuse__mark :global(svg) {
    width: clamp(120px, 18vw, 170px);
    color: var(--text-strong);
  }
  .misuse--stretch .misuse__mark :global(svg) {
    transform: scaleX(1.55);
  }
  .misuse--condense .misuse__mark :global(svg) {
    transform: scaleX(0.55);
  }
  .misuse--rotate .misuse__mark :global(svg) {
    transform: rotate(-9deg);
  }
  .misuse--recolour .misuse__mark :global(svg) {
    color: var(--accent);
  }
  .misuse--effect .misuse__mark :global(svg) {
    filter: drop-shadow(0 6px 6px rgb(0 0 0 / 0.4));
  }
  .misuse--busy {
    background-image: repeating-linear-gradient(
      45deg,
      var(--surface-recessed) 0 10px,
      var(--surface-contrast) 10px 20px
    );
  }
  .misuse__cap {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--text-muted-strong);
    text-wrap: pretty;
  }
  .misuse__x {
    flex: none;
    font-weight: 600;
    color: var(--text-strong);
  }

  /* ---- 04 Colour ---- */
