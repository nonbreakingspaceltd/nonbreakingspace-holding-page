---
import './Motion.css';
import SectionLabel from '../../../../components/SectionLabel';

// 08 — Motion. One curve, reveals and the wipe.
const motionTokens = [
  {
    name: 'Easing',
    detail: 'cubic-bezier(0.22, 1, 0.36, 1) — every transition uses this single curve.',
  },
  { name: 'Reveal', detail: 'Fade + 1.25rem rise over 0.7s, once per element as it scrolls in.' },
  {
    name: 'Wipe',
    detail: 'The wordmark performs a single left-to-right clip-path wipe over 0.9s — written once.',
  },
  {
    name: 'Restraint',
    detail: 'All motion is JS-gated and honours prefers-reduced-motion: reduce.',
  },
];
---

<section id="motion" class="band" aria-labelledby="motion-label">
  <div class="wrap">
    <SectionLabel index="08" label="Motion" id="motion-label" />
    <ul class="motion">
      {
        motionTokens.map((m, i) => (
          <li class="motion__item" data-reveal style={`--reveal-delay: ${i * 50}ms`}>
            <h3 class="t-cap motion__name">{m.name}</h3>
            <p class="t-body">{m.detail}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
